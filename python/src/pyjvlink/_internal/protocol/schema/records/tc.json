    {
      "name": "after_post_time",
      "item_number": 11,
      "wire_type": "string",
      "semantic_type": "time_hhmm",
      "byte_position": 36,
      "byte_size": 4,
      "display": {"label": "変更後発走時刻", "width_type": "half", "char_count": 4}
    },
    {
      "name": "before_post_time",
      "item_number": 12,
      "wire_type": "string",
      "semantic_type": "time_hhmm",
      "byte_position": 40,
      "byte_size": 4,
      "display": {"label": "変更前発走時刻", "width_type": "half", "char_count": 4}
    }
  ]
